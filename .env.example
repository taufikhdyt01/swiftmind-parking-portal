# Copy to .env and adjust as needed. .env is gitignored.

# --- PostgreSQL ---
POSTGRES_USER=swiftmind
POSTGRES_PASSWORD=swiftmind
POSTGRES_DB=swiftmind
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_USER=swiftmind
RABBITMQ_PASSWORD=swiftmind
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=swiftmind
MINIO_ROOT_PASSWORD=swiftmind123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=violation-photos

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ISSUER=swiftmind
ACCESS_TOKEN_TTL=24h

# --- Gateway ---
GATEWAY_PORT=8080
