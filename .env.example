# Copy to .env and adjust as needed. .env is gitignored.

# --- PostgreSQL ---
POSTGRES_USER=parkwatch
POSTGRES_PASSWORD=parkwatch
POSTGRES_DB=parkwatch
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_USER=parkwatch
RABBITMQ_PASSWORD=parkwatch
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Redis ---
REDIS_PORT=6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=parkwatch
MINIO_ROOT_PASSWORD=parkwatch123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=violation-photos

# --- Auth ---
JWT_SECRET=change-me-in-production
