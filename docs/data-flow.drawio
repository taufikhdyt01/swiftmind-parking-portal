<mxfile host="app.diagrams.net" type="device">
  <diagram name="Data Flow" id="dataflow-1">
    <mxGraphModel dx="1040" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ParkWatch — Data Flow Between Services (solid = sync HTTP, dashed = async event via RabbitMQ)" style="text;html=1;fontSize=16;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="web" value="Web App (Next.js)&#10;Officer + Member, one app" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#3b82f6;" vertex="1" parent="1">
          <mxGeometry x="450" y="80" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="gw" value="API Gateway — single entrypoint&#10;JWT verify · RBAC · httpOnly cookie · X-User-* headers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;fontColor=#ffffff;strokeColor=#0f172a;" vertex="1" parent="1">
          <mxGeometry x="380" y="180" width="340" height="56" as="geometry" />
        </mxCell>

        <mxCell id="identity" value="identity&#10;users · login · JWT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="160" height="64" as="geometry" />
        </mxCell>
        <mxCell id="rules" value="rules&#10;rule versions · active set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;" vertex="1" parent="1">
          <mxGeometry x="240" y="320" width="160" height="64" as="geometry" />
        </mxCell>
        <mxCell id="violation" value="violation&#10;submit · fine snapshot · photo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;" vertex="1" parent="1">
          <mxGeometry x="440" y="320" width="160" height="64" as="geometry" />
        </mxCell>
        <mxCell id="payment" value="payment&#10;invoices · mock charge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;" vertex="1" parent="1">
          <mxGeometry x="640" y="320" width="160" height="64" as="geometry" />
        </mxCell>
        <mxCell id="notification" value="notification&#10;consume events · store" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccfbf1;strokeColor=#0d9488;" vertex="1" parent="1">
          <mxGeometry x="840" y="320" width="160" height="64" as="geometry" />
        </mxCell>

        <mxCell id="mq" value="RabbitMQ — parkwatch.events (topic exchange)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontColor=#9a3412;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="480" width="480" height="48" as="geometry" />
        </mxCell>

        <mxCell id="pg" value="PostgreSQL&#10;a schema per service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis&#10;active-ruleset cache · pay lock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1">
          <mxGeometry x="260" y="630" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="minio" value="MinIO (S3)&#10;violation photos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#94a3b8;" vertex="1" parent="1">
          <mxGeometry x="480" y="630" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_web_gw" value="/api/* (cookie)" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="web" target="gw"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_gw_id" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="gw" target="identity"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_gw_ru" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="gw" target="rules"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_gw_vi" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="gw" target="violation"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_gw_pa" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="gw" target="payment"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_gw_no" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="gw" target="notification"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_vi_ru" value="active ruleset (sync)" style="endArrow=block;html=1;strokeColor=#334155;" edge="1" parent="1" source="violation" target="rules"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e_vi_mq" value="violation.created" style="endArrow=block;html=1;dashed=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="violation" target="mq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_pa_mq" value="payment.completed" style="endArrow=block;html=1;dashed=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="payment" target="mq"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_mq_pa" value="create invoice" style="endArrow=block;html=1;dashed=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="mq" target="payment"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_mq_vi" value="mark paid" style="endArrow=block;html=1;dashed=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="mq" target="violation"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_mq_no" value="notify member" style="endArrow=block;html=1;dashed=1;strokeColor=#ea580c;fontColor=#c2410c;" edge="1" parent="1" source="mq" target="notification"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
